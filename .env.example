# Database. Supabase direct connection string (not pooled)
DATABASE_URL=

# OpenAI, for text-embedding-3-small
OPENAI_API_KEY=

# MCP server bearer tokens, one per team member
# Generate with: openssl rand -base64 32
MCP_TOKEN_1=
MCP_TOKEN_2=

# Server port (Railway sets this automatically)
PORT=8080

# Public URL of this server, used by /.well-known/oauth-* discovery
# endpoints. Set to your Railway URL in production (e.g.
# https://<your-app>.up.railway.app). Leave blank for local dev.
BASE_URL=
